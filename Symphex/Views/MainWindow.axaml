<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Symphex.ViewModels"
        xmlns:converters="using:Symphex.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="Symphex.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Symphex - Music Downloader"
        MinWidth="1200" MinHeight="800"
        Background="#0d1117">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<!-- Primary Button Style -->
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#117df7"/>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="8" OffsetX="0" OffsetY="2"/>
			</Setter>
		</Style>
		<Style Selector="Button.primary:pointerover">
			<Setter Property="Background" Value="#0d7dfc"/>
			<Setter Property="RenderTransform" Value="scale(1.03) translateY(-1px)"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="16" OffsetX="0" OffsetY="4"/>
			</Setter>
		</Style>
		<Style Selector="Button.primary:pressed">
			<Setter Property="Background" Value="#489bfa"/>
			<Setter Property="RenderTransform" Value="scale(0.98)"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="4" OffsetX="0" OffsetY="1"/>
			</Setter>
		</Style>

		<!-- Secondary Button Style -->
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="#21262d"/>
			<Setter Property="Foreground" Value="#f0f6fc"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#30363d"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,12"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="3" OffsetX="0" OffsetY="1"/>
			</Setter>
		</Style>
		<Style Selector="Button.secondary:pointerover">
			<Setter Property="Background" Value="#30363d"/>
			<Setter Property="BorderBrush" Value="#58a6ff"/>
			<Setter Property="RenderTransform" Value="scale(1.02) translateY(-1px)"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="12" OffsetX="0" OffsetY="3"/>
			</Setter>
		</Style>
		<Style Selector="Button.secondary:pressed">
			<Setter Property="Background" Value="#1c2128"/>
			<Setter Property="RenderTransform" Value="scale(0.98)"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="2" OffsetX="0" OffsetY="1"/>
			</Setter>
		</Style>

		<!-- Accent Button Style -->
		<Style Selector="Button.accent">
			<Setter Property="Background">
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Color="#58a6ff" Offset="0"/>
					<GradientStop Color="#489bfa" Offset="1"/>
				</LinearGradientBrush>
			</Setter>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="20,16"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="#58a6ff" Opacity="0.3" BlurRadius="20" OffsetX="0" OffsetY="4"/>
			</Setter>
		</Style>
		<Style Selector="Button.accent:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.05) translateY(-2px)"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="#58a6ff" Opacity="0.5" BlurRadius="30" OffsetX="0" OffsetY="6"/>
			</Setter>
		</Style>

		<!-- Card Style -->
		<Style Selector="Border.card">
			<Setter Property="Background" Value="#161b22"/>
			<Setter Property="BorderBrush" Value="#30363d"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="16" OffsetX="0" OffsetY="4"/>
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.card:pointerover">
			<Setter Property="BorderBrush" Value="#0d7dfc"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="24" OffsetX="0" OffsetY="6"/>
			</Setter>
		</Style>

		<!-- Feature Card Style -->
		<Style Selector="Border.feature-card">
			<Setter Property="Background">
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Color="#161b22" Offset="0"/>
					<GradientStop Color="#1c2128" Offset="1"/>
				</LinearGradientBrush>
			</Setter>
			<Setter Property="BorderBrush" Value="#30363d"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" OffsetX="0" OffsetY="6"/>
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.feature-card:pointerover">
			<Setter Property="BorderBrush" Value="#58a6ff"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="#58a6ff" Opacity="0.15" BlurRadius="30" OffsetX="0" OffsetY="10"/>
			</Setter>
		</Style>

		<!-- Modern TextBox Style -->
		<Style Selector="TextBox.modern">
			<Setter Property="Background" Value="#0d1117"/>
			<Setter Property="BorderBrush" Value="#30363d"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="14,12"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Foreground" Value="#f0f6fc"/>
			<Setter Property="CaretBrush" Value="#58a6ff"/>
			<Setter Property="SelectionBrush" Value="#58a6ff40"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="TextBox.modern:focus /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="#58a6ff"/>
		</Style>
		<Style Selector="TextBox.modern:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="#58a6ff"/>
		</Style>

		<!-- Player Button Style -->
		<Style Selector="Button.player">
			<Setter Property="Background" Value="#21262d"/>
			<Setter Property="Foreground" Value="#f0f6fc"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="50"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.player:pointerover">
			<Setter Property="Background" Value="#30363d"/>
		</Style>
		<Style Selector="Button.player:pressed">
			<Setter Property="Background" Value="#58a6ff"/>
		</Style>

		<!-- Play/Pause Button Style -->
		<Style Selector="Button.play-pause">
			<Setter Property="Background" Value="#58a6ff"/>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="50"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="FontSize" Value="20"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="#58a6ff" Opacity="0.3" BlurRadius="16" OffsetX="0" OffsetY="4"/>
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.play-pause:pointerover">
			<Setter Property="Background" Value="#489bfa"/>
			<Setter Property="Effect">
				<DropShadowEffect Color="#58a6ff" Opacity="0.5" BlurRadius="20" OffsetX="0" OffsetY="6"/>
			</Setter>
		</Style>

		<!-- Scrollbar Styling -->
		<Style Selector="ScrollViewer /template/ ScrollBar">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="ScrollViewer /template/ ScrollBar:vertical /template/ Thumb">
			<Setter Property="Background" Value="#30363d"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>
		<Style Selector="ScrollViewer /template/ ScrollBar:vertical /template/ Thumb:pointerover">
			<Setter Property="Background" Value="#484f58"/>
		</Style>

		<!-- CORRECTED Slider Style - Fix thumb clipping -->
		<Style Selector="Slider">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Height" Value="24"/>
			<Setter Property="Padding" Value="0,8"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Margin" Value="8,0"/>
		</Style>

		<Style Selector="Slider /template/ Grid">
			<Setter Property="Margin" Value="0,4"/>
		</Style>

		<Style Selector="Slider /template/ Thumb">
			<Setter Property="Background" Value="#58a6ff"/>
			<Setter Property="Width" Value="16"/>
			<Setter Property="Height" Value="16"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="BorderBrush" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="ZIndex" Value="10"/>
		</Style>

		<Style Selector="Slider /template/ Thumb:pointerover">
			<Setter Property="Background" Value="#489bfa"/>
			<Setter Property="BorderBrush" Value="#ffffff"/>
			<Setter Property="Width" Value="18"/>
			<Setter Property="Height" Value="18"/>
			<Setter Property="CornerRadius" Value="9"/>
		</Style>

		<Style Selector="Slider /template/ Thumb:pressed">
			<Setter Property="Background" Value="#0d7dfc"/>
			<Setter Property="BorderBrush" Value="#ffffff"/>
		</Style>

		<Style Selector="Slider /template/ Border#PART_Track">
			<Setter Property="Background" Value="#21262d"/>
			<Setter Property="Height" Value="4"/>
			<Setter Property="CornerRadius" Value="2"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
	</Window.Styles>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Main Content -->
		<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
			<Grid Margin="24">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="400"/>
					<ColumnDefinition Width="24"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="24"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="24"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="24"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Header Section - spans all columns -->
				<Grid Grid.Row="0" Grid.ColumnSpan="3">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<Border Width="56" Height="56" CornerRadius="16" Margin="0,0,20,0">
							<Border.Background>
								<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
									<GradientStop Color="#58a6ff" Offset="0"/>
									<GradientStop Color="#489bfa" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<Border.Effect>
								<DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="16" OffsetX="0" OffsetY="4"/>
							</Border.Effect>
							<TextBlock Text="♫" FontSize="28" FontWeight="Bold" Foreground="#ffffff"
									   HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="Symphex" FontSize="32" FontWeight="Bold" Foreground="#f0f6fc"/>
							<TextBlock Text="Music Downloader with Album Art" FontSize="16" Foreground="#8b949e"/>
						</StackPanel>
					</StackPanel>
				</Grid>

				<!-- Input Section - left column -->
				<Border Grid.Row="2" Grid.Column="0" Classes="card" Padding="32">
					<StackPanel Spacing="24">
						<TextBlock Text="Enter URL or Search Query" FontSize="18" FontWeight="SemiBold" Foreground="#f0f6fc"/>

						<TextBox Name="UrlTextBox"
								 Text="{Binding DownloadUrl}"
								 Classes="modern"
								 Watermark="https://youtube.com/watch?v=... or search for any song"
								 Height="52"/>

						<StackPanel Orientation="Horizontal" Spacing="16">
							<Button Content="Download" Command="{Binding DownloadCommand}" Classes="primary"/>
							<Button Content="Clear" Command="{Binding ClearCommand}" Classes="secondary"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Main Content Area - left column -->
				<Grid Grid.Row="4" Grid.Column="0">
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="16"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Fixed Preview Section -->
					<Border Grid.Row="0" Classes="card" Padding="28">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="20"/>
								<RowDefinition Height="140"/>
								<RowDefinition Height="16"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="12"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Grid.Row="0" Text="Preview" FontSize="18" FontWeight="SemiBold" Foreground="#f0f6fc"/>

							<!-- Album Art -->
							<Border Grid.Row="2" Width="140" Height="140" CornerRadius="16" Background="#21262d"
									BorderBrush="#30363d" BorderThickness="1" HorizontalAlignment="Center">
								<Border.Effect>
									<DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" OffsetX="0" OffsetY="6"/>
								</Border.Effect>
								<Grid>
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
										<TextBlock Text="🎵" FontSize="40" Foreground="#489bfa"/>
										<TextBlock Text="Album Art" FontSize="11" Foreground="#6e7681" FontWeight="Medium"/>
									</StackPanel>
									<Image Source="{Binding CurrentTrack.AlbumArt}" Stretch="UniformToFill"/>
								</Grid>
							</Border>

							<!-- Track Info -->
							<StackPanel Grid.Row="4" Spacing="4" HorizontalAlignment="Center">
								<TextBlock Text="{Binding CurrentTrack.Title, FallbackValue='Ready to download...'}"
										   FontSize="15" FontWeight="Bold" Foreground="#f0f6fc"
										   TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center" MaxLines="2"/>

								<TextBlock Text="{Binding CurrentTrack.Artist, FallbackValue='Enter a URL above'}"
										   FontSize="13" Foreground="#8b949e"
										   TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center" MaxLines="1"/>

								<TextBlock Text="{Binding CurrentTrack.Album}" FontSize="11" Foreground="#6e7681"
										   IsVisible="{Binding CurrentTrack.Album, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
										   TextWrapping="Wrap" MaxWidth="320" TextAlignment="Center" MaxLines="1"/>
							</StackPanel>

							<!-- Status badge -->
							<Border Grid.Row="6" Background="#489bfa" CornerRadius="16" Padding="10,5" HorizontalAlignment="Center"
									IsVisible="{Binding CurrentTrack.AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}">
								<Border.Effect>
									<DropShadowEffect Color="#489bfa" Opacity="0.3" BlurRadius="8" OffsetX="0" OffsetY="2"/>
								</Border.Effect>
								<TextBlock Text="{Binding CurrentTrack.HasRealAlbumArt, Converter={x:Static converters:BoolToAlbumArtStatusConverter.Instance}}"
										   FontSize="10" FontWeight="SemiBold" Foreground="#ffffff"/>
							</Border>

							<!-- Download progress -->
							<StackPanel Grid.Row="8" IsVisible="{Binding IsDownloading}" Spacing="6">
								<Grid>
									<TextBlock Text="Downloading..." FontSize="12" Foreground="#8b949e"/>
									<TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:0}%'}"
											   FontSize="12" FontWeight="Bold" Foreground="#489bfa" HorizontalAlignment="Right"/>
								</Grid>
								<Border Background="#21262d" Height="6" CornerRadius="3" BorderBrush="#30363d" BorderThickness="1">
									<Border CornerRadius="2" HorizontalAlignment="Left" Background="#489bfa"
											Width="{Binding DownloadProgress, Converter={x:Static converters:PercentageToWidthConverter.Instance}}">
										<Border.Effect>
											<DropShadowEffect Color="#489bfa" Opacity="0.5" BlurRadius="4" OffsetX="0" OffsetY="0"/>
										</Border.Effect>
									</Border>
								</Border>
							</StackPanel>
						</Grid>
					</Border>

					<!-- Status Panel -->
					<Border Grid.Row="2" Classes="card" Padding="20">
						<StackPanel Spacing="12">
							<TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" Foreground="#f0f6fc"/>

							<Border Background="#0d1117" CornerRadius="8" BorderBrush="#30363d" BorderThickness="1" Height="80">
								<ScrollViewer Name="CliOutput" Padding="12" VerticalScrollBarVisibility="Auto">
									<TextBlock Text="{Binding CliOutput}" TextWrapping="Wrap" FontSize="12"
											   Foreground="#e6edf3" LineHeight="16"/>
								</ScrollViewer>
							</Border>
						</StackPanel>
					</Border>
				</Grid>

				<!-- Coming Soon Section -->
				<Border Grid.Row="2" Grid.RowSpan="5" Grid.Column="2" Classes="feature-card" Padding="50">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="32"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<!-- Header -->
						<StackPanel Grid.Row="0" Spacing="12" HorizontalAlignment="Center">
							<Border Width="80" Height="80" CornerRadius="20" HorizontalAlignment="Center">
								<Border.Background>
									<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
										<GradientStop Color="#58a6ff" Offset="0"/>
										<GradientStop Color="#489bfa" Offset="1"/>
									</LinearGradientBrush>
								</Border.Background>
								<Border.Effect>
									<DropShadowEffect Color="#58a6ff" Opacity="0.3" BlurRadius="20" OffsetX="0" OffsetY="6"/>
								</Border.Effect>
								<TextBlock Text="🚀" FontSize="40" Foreground="#ffffff"
										   HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
							<TextBlock Text="Coming Soon" FontSize="28" FontWeight="Bold" Foreground="#f0f6fc"
									   HorizontalAlignment="Center"/>
							<TextBlock Text="Exciting new features are in development!"
									   FontSize="16" Foreground="#8b949e" TextAlignment="Center"/>
						</StackPanel>

						<!-- Feature List -->
						<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
							<StackPanel Spacing="20" Margin="0,20">
								<Border Background="#1c2128" CornerRadius="12" Padding="24" BorderBrush="#30363d" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="12">
											<Border Width="40" Height="40" CornerRadius="10" Background="#238636">
												<TextBlock Text="📚" FontSize="20" Foreground="White"
														   HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<StackPanel VerticalAlignment="Center">
												<TextBlock Text="Playlist Support" FontSize="16" FontWeight="SemiBold" Foreground="#f0f6fc"/>
												<TextBlock Text="Download entire playlists at once" FontSize="13" Foreground="#8b949e"/>
											</StackPanel>
										</StackPanel>
										<TextBlock Text="Import and download complete playlists from YouTube, Spotify links, and other sources with batch processing capabilities."
												   FontSize="12" Foreground="#6e7681" TextWrapping="Wrap" Margin="52,0,0,0"/>
									</StackPanel>
								</Border>

								<Border Background="#1c2128" CornerRadius="12" Padding="24" BorderBrush="#30363d" BorderThickness="1">
									<StackPanel Spacing="12">
										<StackPanel Orientation="Horizontal" Spacing="12">
											<Border Width="40" Height="40" CornerRadius="10" Background="#a855f7">
												<TextBlock Text="🎨" FontSize="20" Foreground="White"
														   HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<StackPanel VerticalAlignment="Center">
												<TextBlock Text="Advanced Metadata" FontSize="16" FontWeight="SemiBold" Foreground="#f0f6fc"/>
												<TextBlock Text="Smart tagging and organization" FontSize="13" Foreground="#8b949e"/>
											</StackPanel>
										</StackPanel>
										<TextBlock Text="Automatic genre detection, lyrics embedding, and intelligent file organization with customizable naming patterns."
												   FontSize="12" Foreground="#6e7681" TextWrapping="Wrap" Margin="52,0,0,0"/>
									</StackPanel>
								</Border>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Border>

				<!-- Footer Section -->
				<Border Grid.Row="6" Grid.Column="0" Background="#21262d" CornerRadius="12" Padding="20"
						BorderBrush="#30363d" BorderThickness="1">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
						<TextBlock Text="📁  Downloads:" FontSize="14" Foreground="#8b949e" Margin="10"/>
						<Button Content="Open Folder" Command="{Binding OpenFolderCommand}"
								Classes="secondary" Padding="12,8" FontSize="13"/>
					</StackPanel>
				</Border>
			</Grid>
		</ScrollViewer>

		<!-- Music Player - Fixed at bottom -->
		<Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="24,20" Height="120">
			<Border.Effect>
				<DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" OffsetX="0" OffsetY="-4"/>
			</Border.Effect>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="300"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="200"/>
				</Grid.ColumnDefinitions>

				<!-- Song Info -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
					<Border Width="50" Height="50" CornerRadius="6" Background="#21262d" BorderBrush="#30363d" BorderThickness="1">
						<Grid>
							<TextBlock Text="🎵" FontSize="20" Foreground="#489bfa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
							<Image Source="{Binding CurrentTrack.AlbumArt}" Stretch="UniformToFill"/>
						</Grid>
					</Border>
					<StackPanel VerticalAlignment="Center" Spacing="2">
						<TextBlock Text="{Binding CurrentTrack.Title, FallbackValue='No song loaded'}"
								   FontSize="13" FontWeight="SemiBold" Foreground="#f0f6fc" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
						<TextBlock Text="{Binding CurrentTrack.Artist, FallbackValue='Select a track to play'}"
								   FontSize="11" Foreground="#8b949e" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
					</StackPanel>
				</StackPanel>

				<!-- Player Controls -->
				<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="12" HorizontalAlignment="Center">
					<!-- Transport Controls -->
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
						<Button Command="{Binding SkipBackCommand}" Classes="player" Width="36" Height="36">
							<TextBlock Text="⏮" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
						<Button Command="{Binding PlayPauseCommand}" Classes="play-pause" Width="44" Height="44">
							<TextBlock Text="{Binding IsPlaying, Converter={x:Static converters:BoolToPlayPauseIconConverter.Instance}}"
									   FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
						<Button Command="{Binding SkipForwardCommand}" Classes="player" Width="36" Height="36">
							<TextBlock Text="⏭" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Button>
					</StackPanel>

					<!-- Progress Bar -->
					<Grid MinWidth="400">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="40"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="40"/>
						</Grid.ColumnDefinitions>

						<TextBlock Grid.Column="0" Text="{Binding CurrentTime, StringFormat={}{0:mm\\:ss}}"
								   FontSize="11" Foreground="#8b949e" VerticalAlignment="Center" HorizontalAlignment="Center"/>

						<Slider Grid.Column="1" Name="ProgressSlider"
								Minimum="0" Maximum="100" Value="{Binding ProgressPercentage, Mode=TwoWay}"
								IsEnabled="{Binding IsPlayingTrack}"
								Margin="16,0"
								Height="24"
								VerticalAlignment="Center"/>

						<TextBlock Grid.Column="2" Text="{Binding CurrentTrack.Duration, FallbackValue='0:00'}"
								   FontSize="11" Foreground="#8b949e" VerticalAlignment="Center" HorizontalAlignment="Center"/>
					</Grid>
				</StackPanel>

				<!-- Volume Control -->
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
					<TextBlock Text="{Binding Volume, Converter={x:Static converters:VolumeToIconConverter.Instance}}"
							   FontSize="14" Foreground="#8b949e" VerticalAlignment="Center"/>

					<Slider Name="VolumeSlider"
							Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}"
							Width="80"
							Height="24"
							IsEnabled="{Binding IsPlayingTrack}"
							VerticalAlignment="Center"/>

					<TextBlock Text="{Binding Volume, StringFormat='{}{0:0}%'}"
							   FontSize="11" Foreground="#8b949e" VerticalAlignment="Center" MinWidth="25"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>