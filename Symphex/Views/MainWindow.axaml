<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Symphex.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Symphex.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Symphex - Music Downloader v1.0"
        MinWidth="1000" MinHeight="700"
        Background="#0a0a0a"
        WindowStartupLocation="CenterScreen">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<!-- Main Container -->
		<Style Selector="Border.container">
			<Setter Property="Background" Value="#1a1a1a"/>
			<Setter Property="BorderBrush" Value="#2a2a2a"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
		</Style>

		<!-- Card Container -->
		<Style Selector="Border.card">
			<Setter Property="Background" Value="#1e1e1e"/>
			<Setter Property="BorderBrush" Value="#333333"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>

		<!-- Primary Button -->
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#0066cc"/>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="32,14"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Height" Value="48"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.primary:pointerover">
			<Setter Property="Background" Value="#0052a3"/>
		</Style>
		<Style Selector="Button.primary:pressed">
			<Setter Property="Background" Value="#004080"/>
		</Style>

		<!-- Secondary Button -->
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="#2a2a2a"/>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#404040"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="16,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Height" Value="36"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.secondary:pointerover">
			<Setter Property="Background" Value="#404040"/>
			<Setter Property="BorderBrush" Value="#0066cc"/>
		</Style>

		<!-- Input Field -->
		<Style Selector="TextBox.input">
			<Setter Property="Background" Value="#2a2a2a"/>
			<Setter Property="BorderBrush" Value="#404040"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,14"/>
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="Foreground" Value="#ffffff"/>
			<Setter Property="CaretBrush" Value="#0066cc"/>
			<Setter Property="SelectionBrush" Value="#0066cc40"/>
			<Setter Property="Height" Value="52"/>
		</Style>
		<Style Selector="TextBox.input:focus /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="#0066cc"/>
		</Style>

		<!-- Progress Bar -->
		<Style Selector="ProgressBar.modern">
			<Setter Property="Background" Value="#2a2a2a"/>
			<Setter Property="Foreground" Value="#0066cc"/>
			<Setter Property="Height" Value="8"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>

		<!-- Console -->
		<Style Selector="Border.console">
			<Setter Property="Background" Value="#111111"/>
			<Setter Property="BorderBrush" Value="#2a2a2a"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>

		<!-- Format Button -->
		<Style Selector="Button.format">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="#404040"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#cccccc"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.format:pointerover">
			<Setter Property="Background" Value="#2a2a2a"/>
		</Style>
		<Style Selector="Button.format.selected">
			<Setter Property="Background" Value="#0066cc"/>
			<Setter Property="BorderBrush" Value="#0066cc"/>
			<Setter Property="Foreground" Value="#ffffff"/>
		</Style>
	</Window.Styles>

	<!-- Main Grid -->
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Classes="container" Margin="0,0,0,20" Padding="24,16">
			<Grid>
				<StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
					<!-- Logo -->
					<Border Width="44" Height="44" CornerRadius="8" Background="#0066cc">
						<TextBlock Text="♪" FontSize="24" FontWeight="Bold" Foreground="#ffffff"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<!-- Title -->
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Symphex" FontSize="20" FontWeight="Bold" Foreground="#ffffff"/>
						<TextBlock Text="Music Downloader v1.0" FontSize="12" Foreground="#888888"/>
					</StackPanel>
				</StackPanel>

				<!-- Status -->
				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
					<Ellipse Width="8" Height="8" Fill="#00cc66"/>
					<TextBlock Text="Ready" FontSize="12" Foreground="#00cc66"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Main Content -->
		<Border Grid.Row="1" Classes="container" Padding="32,28">
			<StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Center" VerticalAlignment="Center">
				<!-- Main Input Section -->
				<StackPanel Spacing="12">
					<TextBlock Text="Download Music" FontSize="24" FontWeight="Bold" Foreground="#ffffff"
                               HorizontalAlignment="Center"/>
					<TextBlock Text="Paste a YouTube or Spotify URL, or search for any song"
                               FontSize="14" Foreground="#aaaaaa" HorizontalAlignment="Center"/>

					<Grid Margin="0,8,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<TextBox Grid.Column="0" Name="UrlTextBox"
                                 Text="{Binding DownloadUrl}"
                                 Classes="input"
                                 Watermark="Enter URL or search: 'Artist - Song Name'"/>

						<Button Grid.Column="2" Content="Download"
                                Command="{Binding DownloadCommand}"
                                Classes="primary"/>
					</Grid>
				</StackPanel>

				<!-- Download Progress -->
				<Border IsVisible="{Binding IsDownloading}" Classes="card" Padding="24">
					<StackPanel Spacing="16">
						<!-- Current Track Info -->
						<Grid>
							<StackPanel Spacing="4">
								<TextBlock Text="Downloading: Song Name - Artist" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff"/>
								<TextBlock Text="Getting metadata..." FontSize="13" Foreground="#aaaaaa"/>
							</StackPanel>
							<TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:0}%'}"
                                       FontSize="18" FontWeight="Bold" Foreground="#0066cc"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
						</Grid>

						<ProgressBar Value="{Binding DownloadProgress}" Classes="modern" Maximum="100"/>

						<Grid>
							<TextBlock Text="Speed: 2.5 MB/s • ETA: 30s" FontSize="12" Foreground="#888888"/>
							<StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right">
								<Button Content="Pause" Classes="secondary" Height="28" Padding="12,4"/>
								<Button Content="Cancel" Classes="secondary" Height="28" Padding="12,4"/>
							</StackPanel>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Quick Options -->
				<Grid MaxWidth="400" HorizontalAlignment="Center">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<Button Grid.Column="0" Content="📁 Open Downloads" Classes="secondary" Height="40" HorizontalAlignment="Stretch"/>
					<Button Grid.Column="2" Content="⚙️ Settings" Classes="secondary" Height="40" HorizontalAlignment="Stretch"/>
				</Grid>
			</StackPanel>
		</Border>
	</Grid>
</Window>